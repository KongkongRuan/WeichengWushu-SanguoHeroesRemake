# ============================================================
# 危城无双之三国群英 H5 还原版 - .gitignore
# ============================================================

# ------------------------------------------------------------
# Node.js / npm
# ------------------------------------------------------------
**/node_modules/
**/npm-debug.log*
**/npm-error.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# ------------------------------------------------------------
# 构建输出
# ------------------------------------------------------------
**/dist/
**/build/
**/.vite/
**/*.tsbuildinfo

# ------------------------------------------------------------
# IDE / 编辑器
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ------------------------------------------------------------
# 操作系统
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# ------------------------------------------------------------
# 日志与临时文件
# ------------------------------------------------------------
*.log
*.tmp
*.bak
*.cache

# ------------------------------------------------------------
# Python (辅助脚本)
# ------------------------------------------------------------
**/__pycache__/
*.pyc
*.pyo
*.egg-info/

# ------------------------------------------------------------
# 环境变量与密钥
# ------------------------------------------------------------
.env
.env.local
.env.*.local
